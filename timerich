<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="description" content="투자 시점을 미루면 얼마나 큰 기회를 놓치는지 복리 시뮬레이션으로 확인해보세요. TimeRich 복리 계산기">
    <title>TimeRich - 복리 시뮬레이터</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons (버전 고정) -->
    <script src="https://unpkg.com/lucide@0.441.0"></script>
    
    <style>
        @keyframes shine {
            100% { left: 100%; }
        }
        .animate-shine {
            animation: shine 1s ease-in-out infinite;
        }
        body {
            background-color: #0B0F19;
            color: #e2e8f0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }
        ::-webkit-scrollbar {
            display: none;
        }
        
        /* 커스텀 슬라이더 */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            height: 8px;
            border-radius: 4px;
            background: #1e293b;
            outline: none;
            transition: background 0.1s;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #ffffff;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
            cursor: pointer;
        }
        input[type=range]::-moz-range-thumb {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #ffffff;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
            cursor: pointer;
            border: none;
        }
        
        .fade-in {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body class="selection:bg-emerald-500/30 flex justify-center pb-20 min-h-screen">
    
    <div class="w-full max-w-xl mx-auto flex flex-col relative">
        
        <!-- 상단 헤더 -->
        <header class="sticky top-0 z-50 bg-[#0B0F19]/80 backdrop-blur-xl border-b border-white/5 px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-xl bg-gradient-to-tr from-emerald-500 to-teal-400 flex items-center justify-center shadow-lg shadow-emerald-500/20">
                    <i data-lucide="trending-up" class="w-5 h-5 text-white"></i>
                </div>
                <h1 class="text-lg font-bold text-white tracking-tight">TimeRich</h1>
            </div>
            <button id="btn-reset" class="text-xs font-semibold px-3 py-1.5 rounded-full bg-white/10 hover:bg-white/20 transition-colors text-white">
                초기화
            </button>
        </header>

        <main class="flex-1 px-5 pt-8 pb-10 space-y-8">
            
            <!-- 메인 카피 -->
            <div class="fade-in" style="transition-delay: 0ms;">
                <h2 class="text-3xl font-extrabold text-white mb-2 leading-tight">
                    투자를 5년 미루면 <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-500">
                        매일 <span id="out-daily-loss">0원</span>
                    </span>씩<br/>
                    버리는 것과 같습니다.
                </h2>
                <p class="text-slate-400 text-sm mt-3">
                    현재 나이 <span id="out-current-age-text">30</span>세, <span id="out-retire-age-text">65</span>세 은퇴 기준
                </p>
            </div>

            <!-- 메인 결과 카드 -->
            <div class="relative overflow-hidden rounded-3xl p-6 fade-in bg-gradient-to-br from-slate-800/80 to-slate-900/80 border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.3)] backdrop-blur-md" style="transition-delay: 100ms;">
                <div class="absolute -top-20 -right-20 w-64 h-64 bg-emerald-500/20 blur-[80px] rounded-full pointer-events-none"></div>
                <div class="relative z-10">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="px-2.5 py-1 rounded-md bg-emerald-500/20 text-emerald-400 text-xs font-bold tracking-wider uppercase">Best Choice</span>
                    </div>
                    <h3 class="text-slate-300 font-medium mb-6">지금 당장 시작했을 때 은퇴 자산</h3>
                    <div class="text-4xl md:text-5xl font-black text-white tracking-tight mb-2 flex items-baseline gap-1">
                        <span id="out-now-fv">0</span>
                        <span class="text-2xl text-emerald-400">원</span>
                    </div>
                    <div class="flex items-center gap-3 mt-6 pt-5 border-t border-white/10">
                        <div class="flex-1">
                            <p class="text-xs text-slate-400 mb-1">총 납입 원금</p>
                            <p class="text-sm font-semibold text-slate-200" id="out-now-principal">0원</p>
                        </div>
                        <div class="w-px h-8 bg-white/10"></div>
                        <div class="flex-1">
                            <p class="text-xs text-slate-400 mb-1">복리 이자 수익</p>
                            <p class="text-sm font-semibold text-emerald-400" id="out-now-interest">+0원</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 바 차트 섹션 -->
            <div class="space-y-5 fade-in" style="transition-delay: 200ms;">
                <h3 class="text-lg font-bold text-white flex items-center">
                    <i data-lucide="alert-triangle" class="w-5 h-5 mr-2 text-orange-400"></i>
                    시작 시기에 따른 자산 격차
                </h3>

                <!-- 즉시 시작 -->
                <div class="group relative">
                    <div class="flex justify-between text-sm mb-2">
                        <span class="font-semibold text-emerald-400">지금 즉시 시작</span>
                        <span class="font-bold text-white" id="out-now-short-fv">0</span>
                    </div>
                    <div class="h-3 w-full bg-slate-800 rounded-full overflow-hidden shadow-inner">
                        <div id="bar-now-fv" class="h-full bg-gradient-to-r from-emerald-600 to-emerald-400 rounded-full transition-all duration-1000 ease-out w-0"></div>
                    </div>
                </div>

                <!-- 5년 늦게 -->
                <div class="group relative">
                    <div class="flex justify-between text-sm mb-2">
                        <span class="font-medium text-orange-400">5년 늦게 시작</span>
                        <span class="font-bold text-slate-300" id="out-late5-short-fv">0</span>
                    </div>
                    <div class="h-3 w-full bg-slate-800 rounded-full flex overflow-visible shadow-inner relative">
                        <div id="bar-late5-fv" class="h-full bg-gradient-to-r from-orange-600 to-orange-400 rounded-full transition-all duration-1000 ease-out z-10 w-0"></div>
                        <div id="bar-late5-loss" class="absolute top-0 right-0 h-full bg-red-500/20 border border-dashed border-red-500/50 rounded-r-full transition-all duration-1000 ease-out w-0"></div>
                    </div>
                    <p class="text-xs text-red-400 text-right mt-1.5 font-medium flex items-center justify-end">
                        <i data-lucide="zap" class="w-3 h-3 mr-0.5"></i> -<span id="out-late5-loss">0원</span> 증발
                    </p>
                </div>

                <!-- 10년 늦게 -->
                <div class="group relative">
                    <div class="flex justify-between text-sm mb-2">
                        <span class="font-medium text-red-400">10년 늦게 시작</span>
                        <span class="font-bold text-slate-300" id="out-late10-short-fv">0</span>
                    </div>
                    <div class="h-3 w-full bg-slate-800 rounded-full flex overflow-visible shadow-inner relative">
                        <div id="bar-late10-fv" class="h-full bg-gradient-to-r from-red-700 to-red-500 rounded-full transition-all duration-1000 ease-out z-10 w-0"></div>
                        <div id="bar-late10-loss" class="absolute top-0 right-0 h-full bg-red-500/10 border border-dashed border-red-500/30 rounded-r-full transition-all duration-1000 ease-out w-0"></div>
                    </div>
                </div>
            </div>

            <!-- 컨트롤 패널 -->
            <div class="mt-8 bg-[#131B2C] rounded-3xl p-6 border border-white/5 fade-in" style="transition-delay: 300ms;">
                <h3 class="text-white font-bold mb-6">시뮬레이션 조건 설정</h3>
                
                <!-- 월 투자 금액 -->
                <div class="mb-6">
                    <div class="flex justify-between items-end mb-3">
                        <div class="flex items-center text-slate-400 text-sm font-medium">
                            <i data-lucide="wallet" class="w-4 h-4 mr-1.5"></i> 월 투자 금액
                        </div>
                        <div class="text-xl font-bold text-emerald-400"><span id="val-monthly">150</span>만 원</div>
                    </div>
                    <input type="range" id="input-monthly" min="10" max="1000" step="10" value="150">
                </div>
                
                <!-- 연평균 수익률 -->
                <div class="mb-6">
                    <div class="flex justify-between items-end mb-3">
                        <div class="flex items-center text-slate-400 text-sm font-medium">
                            <i data-lucide="trending-up" class="w-4 h-4 mr-1.5"></i> 연평균 수익률
                        </div>
                        <div class="text-xl font-bold text-blue-400"><span id="val-rate">7</span>%</div>
                    </div>
                    <input type="range" id="input-rate" min="1" max="20" step="1" value="7">
                </div>
                
                <!-- 현재 나이 -->
                <div class="mb-6">
                    <div class="flex justify-between items-end mb-3">
                        <div class="flex items-center text-slate-400 text-sm font-medium">
                            <i data-lucide="calendar" class="w-4 h-4 mr-1.5"></i> 현재 나이
                        </div>
                        <div class="text-xl font-bold text-purple-400"><span id="val-age">30</span>세</div>
                    </div>
                    <input type="range" id="input-age" min="20" max="60" step="1" value="30">
                </div>
                
                <!-- 은퇴 목표 나이 -->
                <div class="mb-6">
                    <div class="flex justify-between items-end mb-3">
                        <div class="flex items-center text-slate-400 text-sm font-medium">
                            <i data-lucide="clock" class="w-4 h-4 mr-1.5"></i> 은퇴 목표 나이
                        </div>
                        <div class="text-xl font-bold text-pink-400"><span id="val-retire">65</span>세</div>
                    </div>
                    <input type="range" id="input-retire" min="35" max="90" step="1" value="65">
                </div>
            </div>

        </main>

        <!-- 하단 고정 버튼 -->
        <div class="fixed bottom-0 left-0 w-full bg-gradient-to-t from-[#0B0F19] via-[#0B0F19] to-transparent pt-12 pb-6 px-5 z-50 pointer-events-none flex justify-center">
            <div class="w-full max-w-xl pointer-events-auto">
                <a href="https://booking.allbaro.workers.dev/" target="_blank" rel="noopener noreferrer" 
                   class="w-full relative overflow-hidden group bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-bold text-lg py-4 rounded-2xl shadow-[0_0_20px_rgba(16,185,129,0.4)] transition-all duration-300 transform hover:-translate-y-1 active:translate-y-0 flex items-center justify-center gap-2" 
                   style="text-decoration: none;">
                    <span class="relative z-10">더 늦기 전에 상담 시작하기</span>
                    <i data-lucide="chevron-right" class="w-5 h-5 relative z-10 group-hover:translate-x-1 transition-transform"></i>
                    <div class="absolute top-0 -left-full w-full h-full bg-gradient-to-r from-transparent via-white/40 to-transparent skew-x-12 group-hover:animate-shine"></div>
                </a>
            </div>
        </div>
        
    </div>

    <script>
        lucide.createIcons();
        
        // 페이드인 애니메이션
        setTimeout(() => {
            document.querySelectorAll('.fade-in').forEach(el => el.classList.add('visible'));
        }, 50);

        // DOM 요소
        const inputs = {
            monthly: document.getElementById('input-monthly'),
            rate: document.getElementById('input-rate'),
            age: document.getElementById('input-age'),
            retire: document.getElementById('input-retire')
        };
        const displays = {
            monthly: document.getElementById('val-monthly'),
            rate: document.getElementById('val-rate'),
            age: document.getElementById('val-age'),
            retire: document.getElementById('val-retire')
        };
        const outs = {
            dailyLoss: document.getElementById('out-daily-loss'),
            ageText: document.getElementById('out-current-age-text'),
            retireText: document.getElementById('out-retire-age-text'),
            nowFv: document.getElementById('out-now-fv'),
            nowPrincipal: document.getElementById('out-now-principal'),
            nowInterest: document.getElementById('out-now-interest'),
            nowShortFv: document.getElementById('out-now-short-fv'),
            late5ShortFv: document.getElementById('out-late5-short-fv'),
            late5Loss: document.getElementById('out-late5-loss'),
            late10ShortFv: document.getElementById('out-late10-short-fv')
        };
        const bars = {
            nowFv: document.getElementById('bar-now-fv'),
            late5Fv
